# Copie este arquivo para .env e ajuste os valores antes de subir os containers
# cp .env.example .env

# ── PostgreSQL: Auth ──────────────────────────────────────────────────────────
POSTGRES_AUTH_DB=auth_db
POSTGRES_AUTH_USER=auth_user
POSTGRES_AUTH_PASSWORD=auth_pass

# ── PostgreSQL: Event ─────────────────────────────────────────────────────────
POSTGRES_EVENT_DB=event_db
POSTGRES_EVENT_USER=event_user
POSTGRES_EVENT_PASSWORD=event_pass

# ── PostgreSQL: Booking ───────────────────────────────────────────────────────
POSTGRES_BOOKING_DB=booking_db
POSTGRES_BOOKING_USER=booking_user
POSTGRES_BOOKING_PASSWORD=booking_pass

# ── PostgreSQL: Kong ──────────────────────────────────────────────────────────
POSTGRES_KONG_DB=kong_db
POSTGRES_KONG_USER=kong_user
POSTGRES_KONG_PASSWORD=kong_pass

# ── Zookeeper ─────────────────────────────────────────────────────────────────
ZOOKEEPER_CLIENT_PORT=2181
ZOOKEEPER_TICK_TIME=2000

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BROKER_ID=1
KAFKA_ZOOKEEPER_CONNECT=zookeeper:2181
KAFKA_LISTENER_SECURITY_PROTOCOL_MAP=PLAINTEXT:PLAINTEXT,PLAINTEXT_HOST:PLAINTEXT
KAFKA_ADVERTISED_LISTENERS=PLAINTEXT://kafka:29092,PLAINTEXT_HOST://localhost:9092
KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR=1
KAFKA_TRANSACTION_STATE_LOG_MIN_ISR=1
KAFKA_TRANSACTION_STATE_LOG_REPLICATION_FACTOR=1
KAFKA_AUTO_CREATE_TOPICS_ENABLE=true

# ── Elasticsearch ─────────────────────────────────────────────────────────────
ES_DISCOVERY_TYPE=single-node
ES_XPACK_SECURITY_ENABLED=false
ES_XPACK_SECURITY_ENROLLMENT_ENABLED=false
ES_JAVA_OPTS=-Xms512m -Xmx512m

# ── Debezium ─────────────────────────────────────────────────────────────────
DEBEZIUM_BOOTSTRAP_SERVERS=kafka:29092
DEBEZIUM_GROUP_ID=debezium-connect
DEBEZIUM_CONFIG_STORAGE_TOPIC=debezium.configs
DEBEZIUM_OFFSET_STORAGE_TOPIC=debezium.offsets
DEBEZIUM_STATUS_STORAGE_TOPIC=debezium.statuses
DEBEZIUM_CONFIG_STORAGE_REPLICATION_FACTOR=1
DEBEZIUM_OFFSET_STORAGE_REPLICATION_FACTOR=1
DEBEZIUM_STATUS_STORAGE_REPLICATION_FACTOR=1
DEBEZIUM_CONNECT_KEY_CONVERTER=org.apache.kafka.connect.json.JsonConverter
DEBEZIUM_CONNECT_VALUE_CONVERTER=org.apache.kafka.connect.json.JsonConverter

# ── MinIO (S3 local) ──────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ── Jaeger / OpenTelemetry ────────────────────────────────────────────────────
JAEGER_COLLECTOR_OTLP_ENABLED=true
OTEL_ENDPOINT_HTTP=http://jaeger:4318
OTEL_ENDPOINT_GRPC=http://jaeger:4317

# ── Kong ──────────────────────────────────────────────────────────────────────
KONG_ADMIN_GUI_URL=http://localhost:8002
KONG_PLUGINS=bundled,jwt-claims-injector

# ── Auth Service (NestJS) ─────────────────────────────────────────────────────
AUTH_NODE_ENV=development
AUTH_PORT=3001
AUTH_JWT_PRIVATE_KEY_PATH=./keys/private.pem
AUTH_JWT_PUBLIC_KEY_PATH=./keys/public.pem
AUTH_JWT_ACCESS_EXPIRES_IN=15m
AUTH_JWT_REFRESH_EXPIRES_IN=7
AUTH_OTEL_SERVICE_NAME=auth-service

# ── Event Service (Laravel) ───────────────────────────────────────────────────
# IMPORTANTE: gere uma nova chave com: php artisan key:generate --show
EVENT_SERVICE_APP_KEY=base64:TROQUE_ESTA_CHAVE_GERE_UMA_NOVA
EVENT_APP_ENV=local
EVENT_APP_DEBUG=true
EVENT_DB_CONNECTION=pgsql
EVENT_CACHE_STORE=redis
EVENT_FILESYSTEM_DISK=s3
EVENT_AWS_DEFAULT_REGION=us-east-1
EVENT_AWS_BUCKET=ticketify-media
EVENT_AWS_ENDPOINT=http://minio:9000
EVENT_AWS_USE_PATH_STYLE_ENDPOINT=true
EVENT_AWS_URL=http://localhost:9000/ticketify-media
EVENT_OTEL_SERVICE_NAME=event-service

# ── Search Service (FastAPI) ──────────────────────────────────────────────────
SEARCH_ELASTICSEARCH_URL=http://elasticsearch:9200
SEARCH_ELASTICSEARCH_INDEX=events
SEARCH_OTEL_SERVICE_NAME=search-service

# ── CDC Service (Spring Boot) ─────────────────────────────────────────────────
CDC_KAFKA_BOOTSTRAP_SERVERS=kafka:29092
CDC_ELASTICSEARCH_URL=http://elasticsearch:9200
CDC_ELASTICSEARCH_INDEX=events
CDC_KAFKA_TOPIC_EVENTS=db.public.events
CDC_OTEL_SERVICE_NAME=cdc-service
CDC_OTEL_METRICS_EXPORTER=none
CDC_OTEL_LOGS_EXPORTER=none

# ── Booking Service (Go) ─────────────────────────────────────────────────────
BOOKING_PORT=8020
BOOKING_KAFKA_BROKERS=kafka:29092
BOOKING_KAFKA_TOPIC=ticketify.bookings
BOOKING_OTEL_SERVICE_NAME=booking-service

# ── Frontend (Next.js) ────────────────────────────────────────────────────────
FRONTEND_AUTH_SERVICE_URL=http://auth-service:3001
FRONTEND_EVENT_SERVICE_URL=http://event-service:8080
FRONTEND_SEARCH_SERVICE_URL=http://search-service:8000
FRONTEND_BOOKING_SERVICE_URL=http://booking-service:8020
